using ModelContextProtocol.Server;
using System.ComponentModel;
using System.Diagnostics;
using System.Runtime.InteropServices;

namespace VisualStudioMCP.Tools;

[McpServerToolType]
internal class VisualStudioLauncher
{
    private static readonly string VsWhereBundledPath = Path.Combine(
        AppContext.BaseDirectory,
        "Tools",
        "vswhere.exe");

    private static readonly string VsWhereInstallerPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.ProgramFilesX86),
        "Microsoft Visual Studio",
        "Installer",
        "vswhere.exe");

    /// <summary>
    /// Locates the most recent Visual Studio installation and launches it,
    /// optionally opening a specific solution or folder.
    /// </summary>
    [McpServerTool]
    [Description("Locates the installed location of Visual Studio and launches it. Optionally opens a solution file or folder path.")]
    public async Task<string> LaunchVisualStudio(
        [Description("Optional path to a solution (.sln/.slnx) or folder to open.")] string? pathToOpen = null)
    {
        if (!RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
        {
            return "Visual Studio is only supported on Windows.";
        }

        string devenvPath = await FindVisualStudioAsync();

        var startInfo = new ProcessStartInfo
        {
            FileName = devenvPath,
            UseShellExecute = false,
        };

        if (!string.IsNullOrWhiteSpace(pathToOpen))
        {
            startInfo.ArgumentList.Add(pathToOpen);
        }

        Process.Start(startInfo);

        return string.IsNullOrWhiteSpace(pathToOpen)
            ? $"Visual Studio launched from: {devenvPath}"
            : $"Visual Studio launched from: {devenvPath} opening \"{pathToOpen}\"";
    }

    /// <summary>
    /// Uses vswhere.exe to locate the latest Visual Studio installation
    /// and returns the full path to devenv.exe.
    /// </summary>
    private static async Task<string> FindVisualStudioAsync()
    {
        string vsWherePath = File.Exists(VsWhereBundledPath)
            ? VsWhereBundledPath
            : File.Exists(VsWhereInstallerPath)
                ? VsWhereInstallerPath
                : throw new FileNotFoundException(
                    $"Could not find vswhere.exe at \"{VsWhereBundledPath}\" or \"{VsWhereInstallerPath}\". " +
                    "Ensure the application was published correctly or Visual Studio Installer is installed.");

        var psi = new ProcessStartInfo
        {
            FileName = vsWherePath,
            ArgumentList =
            {
                "-prerelease",
                "-latest",
                "-requires", "Microsoft.Component.MSBuild",
                "-property", "installationPath",
                "-format", "value"
            },
            RedirectStandardOutput = true,
            RedirectStandardError = true,
            UseShellExecute = false,
            CreateNoWindow = true,
        };

        using var process = Process.Start(psi)
            ?? throw new InvalidOperationException("Failed to start vswhere.exe.");

        string output = (await process.StandardOutput.ReadToEndAsync()).Trim();
        await process.WaitForExitAsync();

        if (process.ExitCode != 0 || string.IsNullOrWhiteSpace(output))
        {
            string error = await process.StandardError.ReadToEndAsync();
            throw new InvalidOperationException(
                $"vswhere.exe failed (exit code {process.ExitCode}). {error}".Trim());
        }

        // Take the first line in case multiple installations are returned.
        string installPath = output.Split('\n', StringSplitOptions.RemoveEmptyEntries)[0].Trim();
        string devenvPath = Path.Combine(installPath, "Common7", "IDE", "devenv.exe");

        if (!File.Exists(devenvPath))
        {
            throw new FileNotFoundException(
                $"devenv.exe not found at \"{devenvPath}\". The installation may be corrupted.");
        }

        return devenvPath;
    }
}
